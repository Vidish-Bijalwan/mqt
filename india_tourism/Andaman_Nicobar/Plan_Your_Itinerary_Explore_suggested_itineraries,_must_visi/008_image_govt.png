<script>
$(document).ready(function(){
    let $list = $("#announcementList");
    let $items = $list.find("li");
    let itemHeight = $items.outerHeight();
    let interval;

    function startTicker() {
        interval = setInterval(function(){
            $list.animate({marginTop: -itemHeight}, 600, function(){
                $list.append($list.find("li:first"));
                $list.css({marginTop: 0});
            });
        }, 3000); // every 3 seconds
    }

    function stopTicker() {
        clearInterval(interval);
    }

    // Start ticker
    startTicker();

    // Pause on hover
    $(".announcement-box").hover(stopTicker, startTicker);
});
</script>
    
    <!-- Custom JavaScript -->
    <script>
        class MemoriesSlider {
            constructor() {
                this.currentSlide = 0;
                this.totalSlides = document.querySelectorAll('.image-card').length;
                this.sliderTrack = document.getElementById('sliderTrack');
                this.dots = document.querySelectorAll('.slider-dot');
                this.prevBtn = document.getElementById('prevBtn');
                this.nextBtn = document.getElementById('nextBtn');
                this.autoPlayInterval = null;
                this.cardWidth = 320; // card width + gap
                
                this.init();
            }
            
            init() {
                this.updateSlider();
                this.bindEvents();
                this.startAutoplay();
                this.handleResize();
            }
            
            bindEvents() {
                // Navigation buttons
                this.prevBtn.addEventListener('click', () => {
                    this.prevSlide();
                    this.resetAutoplay();
                });
                
                this.nextBtn.addEventListener('click', () => {
                    this.nextSlide();
                    this.resetAutoplay();
                });
                
                // Dots navigation
                this.dots.forEach((dot, index) => {
                    dot.addEventListener('click', () => {
                        this.goToSlide(index);
                        this.resetAutoplay();
                    });
                });
                
                // Touch/Swipe support
                let startX = 0;
                let isDragging = false;
                
                this.sliderTrack.addEventListener('touchstart', (e) => {
                    isDragging = true;
                    startX = e.touches[0].clientX;
                    this.stopAutoplay();
                });
                
                this.sliderTrack.addEventListener('touchmove', (e) => {
                    if (!isDragging) return;
                    e.preventDefault();
                });
                
                this.sliderTrack.addEventListener('touchend', (e) => {
                    if (!isDragging) return;
                    
                    const endX = e.changedTouches[0].clientX;
                    const diff = startX - endX;
                    
                    if (Math.abs(diff) > 50) {
                        if (diff > 0) {
                            this.nextSlide();
                        } else {
                            this.prevSlide();
                        }
                    }
                    
                    isDragging = false;
                    this.resetAutoplay();
                });
                
                // Pause autoplay on hover
                this.sliderTrack.addEventListener('mouseenter', () => {
                    this.stopAutoplay();
                });
                
                this.sliderTrack.addEventListener('mouseleave', () => {
                    this.startAutoplay();
                });
                
                // Window resize
                window.addEventListener('resize', () => {
                    this.handleResize();
                });
            }
            
            updateSlider() {
                const offset = -this.currentSlide * this.cardWidth;
                this.sliderTrack.style.transform = `translateX(${offset}px)`;
                
                // Update dots
                this.dots.forEach((dot, index) => {
                    dot.classList.toggle('active', index === this.currentSlide);
                });
            }
            
            nextSlide() {
                this.currentSlide = (this.currentSlide + 1) % this.totalSlides;
                this.updateSlider();
            }
            
            prevSlide() {
                this.currentSlide = (this.currentSlide - 1 + this.totalSlides) % this.totalSlides;
                this.updateSlider();
            }
            
            goToSlide(index) {
                this.currentSlide = index;
                this.updateSlider();
            }
            
            startAutoplay() {
                this.autoPlayInterval = setInterval(() => {
                    this.nextSlide();
                }, 4000);
            }
            
            stopAutoplay() {
                if (this.autoPlayInterval) {
                    clearInterval(this.autoPlayInterval);
                    this.autoPlayInterval = null;
                }
            }
            
            resetAutoplay() {
                this.stopAutoplay();
                this.startAutoplay();
            }
            
            handleResize() {
                // Adjust card width based on screen size
                const screenWidth = window.innerWidth;
                if (screenWidth <= 576) {
                    this.cardWidth = 240;
                } else if (screenWidth <= 768) {
                    this.cardWidth = 270;
                } else if (screenWidth <= 1200) {
                    this.cardWidth = 300;
                } else {
                    this.cardWidth = 320;
                }
                this.updateSlider();
            }
        }
        
        // Initialize slider when DOM is loaded
        document.addEventListener('DOMContentLoaded', function() {
            new MemoriesSlider();
        });
        
        // Video background fallback
        document.addEventListener('DOMContentLoaded', function() {
            const video = document.querySelector('.video-background video');
            if (video) {
                video.addEventListener('error', function() {
                    console.log('Video failed to load, showing fallback image');
                    video.style.display = 'none';
                });
            }
        });
    </script>
  <script>
document.addEventListener('DOMContentLoaded', function() {
    // Initialize destinations slider
    const slider = document.getElementById('destinationsSlider');
    const slides = document.querySelectorAll('.destination-slide');
    const prevBtn = document.getElementById('destinationsPrev');
    const nextBtn = document.getElementById('destinationsNext');
    const dotsContainer = document.getElementById('destinationsDots');
    
    let currentSlide = 0;
    let slidesPerView = 3;
    let slideWidth = 100 / slidesPerView;
    
    // Calculate slides per view based on screen size
    function calculateSlidesPerView() {
        if (window.innerWidth >= 1600) {
            return 3;
        } else if (window.innerWidth >= 1200) {
            return 3;
        } else if (window.innerWidth >= 992) {
            return 2;
        } else {
            return 1;
        }
    }
    
    // Create dots
    function createDots() {
        dotsContainer.innerHTML = '';
        const visibleSlides = calculateSlidesPerView();
        const dotCount = Math.max(slides.length - visibleSlides + 1, 1);
        
        for (let i = 0; i < dotCount; i++) {
            const dot = document.createElement('span');
            dot.classList.add('slider-dot');
            if (i === 0) dot.classList.add('active');
            dot.addEventListener('click', () => {
                goToSlide(i);
            });
            dotsContainer.appendChild(dot);
        }
    }
    
    // Update slider position
    function updateSlider() {
        slidesPerView = calculateSlidesPerView();
        slideWidth = 100 / slidesPerView;
        
        slider.style.transform = `translateX(-${currentSlide * slideWidth}%)`;
        
        // Update active dot
        document.querySelectorAll('.slider-dot').forEach((dot, index) => {
            dot.classList.toggle('active', index === currentSlide);
        });
    }
    
    // Go to specific slide
    function goToSlide(index) {
        currentSlide = index;
        updateSlider();
    }
    
    // Next slide
    function nextSlide() {
        const maxSlide = slides.length - calculateSlidesPerView();
        if (currentSlide < maxSlide) {
            currentSlide++;
            updateSlider();
        } else {
            // Loop back to first slide
            currentSlide = 0;
            updateSlider();
        }
    }
    
    // Previous slide
    function prevSlide() {
        if (currentSlide > 0) {
            currentSlide--;
            updateSlider();
        } else {
            // Loop to last slide
            currentSlide = slides.length - calculateSlidesPerView();
            updateSlider();
        }
    }
    
    // Handle window resize
    function handleResize() {
        createDots();
        updateSlider();
    }
    
    // Event listeners
    nextBtn.addEventListener('click', nextSlide);
    prevBtn.addEventListener('click', prevSlide);
    
    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight') nextSlide();
        if (e.key === 'ArrowLeft') prevSlide();
    });
    
    // Initialize slider
    createDots();
    updateSlider();
    
    // Auto-slide
    let autoSlideInterval = setInterval(nextSlide, 5000);
    
    // Pause auto-slide on hover
    slider.addEventListener('mouseenter', () => {
        clearInterval(autoSlideInterval);
    });
    
    slider.addEventListener('mouseleave', () => {
        autoSlideInterval = setInterval(nextSlide, 5000);
    });
    
    // Handle window resize
    window.addEventListener('resize', handleResize);
});
</script>
<script>
        // Auto-scroll functionality for both sections
        document.addEventListener('DOMContentLoaded', function() {
            // News section scrolling
            const newsItems = document.querySelectorAll('#newsWrapper .scroll-item');
            let currentNewsIndex = 0;
            
            function showNextNewsItem() {
                // Remove active class from current item
                newsItems[currentNewsIndex].classList.remove('active');
                newsItems[currentNewsIndex].classList.add('prev');
                
                // Move to next item
                currentNewsIndex = (currentNewsIndex + 1) % newsItems.length;
                
                // Add active class to new item
                setTimeout(() => {
                    newsItems.forEach(item => item.classList.remove('prev'));
                    newsItems[currentNewsIndex].classList.add('active');
                }, 300);
            }
            
            // About section scrolling
            const aboutItems = document.querySelectorAll('#aboutWrapper .scroll-item');
            let currentAboutIndex = 0;
            
            function showNextAboutItem() {
                // Remove active class from current item
                aboutItems[currentAboutIndex].classList.remove('active');
                aboutItems[currentAboutIndex].classList.add('prev');
                
                // Move to next item
                currentAboutIndex = (currentAboutIndex + 1) % aboutItems.length;
                
                // Add active class to new item
                setTimeout(() => {
                    aboutItems.forEach(item => item.classList.remove('prev'));
                    aboutItems[currentAboutIndex].classList.add('active');
                }, 300);
            }
            
            // Start auto-scrolling for both sections
            setInterval(showNextNewsItem, 3000); // Change every 3 seconds
            setInterval(showNextAboutItem, 3500); // Slightly different timing for variety
            
            // Pause scrolling on hover
            const newsWrapper = document.getElementById('newsWrapper');
            const aboutWrapper = document.getElementById('aboutWrapper');
            
            let newsInterval, aboutInterval;
            
            // Restart intervals
            newsInterval = setInterval(showNextNewsItem, 3000);
            aboutInterval = setInterval(showNextAboutItem, 3500);
            
            // Pause on hover
            newsWrapper.addEventListener('mouseenter', () => {
                clearInterval(newsInterval);
            });
            
            newsWrapper.addEventListener('mouseleave', () => {
                newsInterval = setInterval(showNextNewsItem, 3000);
            });
            
            aboutWrapper.addEventListener('mouseenter', () => {
                clearInterval(aboutInterval);
            });
            
            aboutWrapper.addEventListener('mouseleave', () => {
                aboutInterval = setInterval(showNextAboutItem, 3500);
            });
        });
    </script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Intersection Observer for scroll animations
    const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.style.animationPlayState = 'running';
            }
        });
    }, observerOptions);

    // Observe all destination items
    document.querySelectorAll('.destination-item').forEach(item => {
        item.style.animationPlayState = 'paused';
        observer.observe(item);
    });

    // Add click tracking
    document.querySelectorAll('.btn-explore').forEach(btn => {
        btn.addEventListener('click', function(e) {
            const destinationName = this.closest('.destination-item').querySelector('.destination-name').textContent;
            console.log(`Exploring: ${destinationName}`);
        });
    });
});
</script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Initialize sliders for all gallery items
    const galleryItems = document.querySelectorAll('.gallery-item');
    
    galleryItems.forEach(item => {
        const categoryId = item.getAttribute('data-category');
        const slider = item.querySelector('.gallery-slider');
        const slides = item.querySelectorAll('.gallery-slide');
        const indicators = item.querySelectorAll('.indicator');
        
        if (slides.length <= 1) return; // Skip if only one image
        
        let currentSlide = 0;
        let sliderInterval;
        
        // Function to show specific slide
        function showSlide(index) {
            // Remove active class from all slides and indicators
            slides.forEach(slide => slide.classList.remove('active'));
            indicators.forEach(indicator => indicator.classList.remove('active'));
            
            // Add active class to current slide and indicator
            slides[index].classList.add('active');
            if (indicators[index]) {
                indicators[index].classList.add('active');
            }
        }
        
        // Function to go to next slide
        function nextSlide() {
            currentSlide = (currentSlide + 1) % slides.length;
            showSlide(currentSlide);
        }
        
        // Start auto slider
        function startSlider() {
            sliderInterval = setInterval(nextSlide, 3000); // Change slide every 3 seconds
        }
        
        // Stop auto slider
        function stopSlider() {
            clearInterval(sliderInterval);
        }
        
        // Add click handlers to indicators
        indicators.forEach((indicator, index) => {
            indicator.addEventListener('click', () => {
                currentSlide = index;
                showSlide(currentSlide);
                stopSlider();
                startSlider(); // Restart timer
            });
        });
        
        // Pause on hover, resume on mouse leave
        item.addEventListener('mouseenter', stopSlider);
        item.addEventListener('mouseleave', startSlider);
        
        // Start the slider
        startSlider();
    });
});
</script>
<script>
document.addEventListener("DOMContentLoaded", function() {
    function showSlide(sliderId, index) {
        const slider = document.getElementById(sliderId);
        const slides = slider.querySelectorAll(".gallery-slide");
        const indicators = slider.parentElement.querySelectorAll(".indicator");

        if (index >= slides.length) index = 0;
        if (index < 0) index = slides.length - 1;

        slides.forEach((slide, i) => {
            slide.classList.toggle("active", i === index);
        });

        indicators.forEach((ind, i) => {
            ind.classList.toggle("active", i === index);
        });

        slider.dataset.currentIndex = index;
    }

    // Handle next/prev buttons
    document.querySelectorAll(".slider-btn").forEach(btn => {
        btn.addEventListener("click", function() {
            const sliderId = this.dataset.slider;
            const slider = document.getElementById(sliderId);
            let currentIndex = parseInt(slider.dataset.currentIndex || 0);

            if (this.classList.contains("next")) {
                currentIndex++;
            } else {
                currentIndex--;
            }
            showSlide(sliderId, currentIndex);
        });
    });

    // Handle indicator clicks
    document.querySelectorAll(".indicator").forEach(indicator => {
        indicator.addEventListener("click", function() {
            const sliderId = this.closest(".gallery-slider-container").querySelector(".gallery-slider").id;
            const slideIndex = parseInt(this.dataset.slide);
            showSlide(sliderId, slideIndex);
        });
    });
});
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.4/js/lightbox.min.js"></script>
<script>
  const muteBtn = document.getElementById("muteBtn");
  const muteIcon = muteBtn.querySelector("i");

  function getActiveVideo() {
    const activeSlide = document.querySelector(".video-slide.active");
    return activeSlide ? activeSlide.querySelector("video") : null;
  }

  muteBtn.addEventListener("click", () => {
    const video = getActiveVideo();
    if (!video) return;

    if (video.muted) {
      // Unmute the active video
      video.muted = false;
      muteIcon.classList.remove("fa-volume-mute");
      muteIcon.classList.add("fa-volume-up");
      muteBtn.title = "Mute";
    } else {
      // Mute again
      video.muted = true;
      muteIcon.classList.remove("fa-volume-up");
      muteIcon.classList.add("fa-volume-mute");
      muteBtn.title = "Unmute";
    }
  });

  // (Optional) Whenever the slide changes, reset mute button state
  function updateMuteButton() {
    const video = getActiveVideo();
    if (video && video.muted) {
      muteIcon.classList.remove("fa-volume-up");
      muteIcon.classList.add("fa-volume-mute");
      muteBtn.title = "Unmute";
    } else {
      muteIcon.classList.remove("fa-volume-mute");
      muteIcon.classList.add("fa-volume-up");
      muteBtn.title = "Mute";
    }
  }

  // Call updateMuteButton() whenever you change slides in your slider
</script>
  <script>
        // Star Rating Functionality
        document.querySelectorAll('.rating-group').forEach(group => {
            const stars = group.querySelectorAll('.star-rating');
            const ratingType = group.getAttribute('data-rating');
            const hiddenInput = document.getElementById(ratingType + 'Rating');
            
            stars.forEach((star, index) => {
                star.addEventListener('click', () => {
                    const rating = index + 1;
                    hiddenInput.value = rating;
                    
                    stars.forEach((s, i) => {
                        if (i < rating) {
                            s.classList.add('active');
                        } else {
                            s.classList.remove('active');
                        }
                    });
                });
                
                star.addEventListener('mouseenter', () => {
                    stars.forEach((s, i) => {
                        if (i <= index) {
                            s.style.color = '#ffc107';
                        } else {
                            s.style.color = '#ddd';
                        }
                    });
                });
            });
            
            group.addEventListener('mouseleave', () => {
                const currentRating = hiddenInput.value;
                stars.forEach((s, i) => {
                    if (i < currentRating) {
                        s.style.color = '#ffc107';
                    } else {
                        s.style.color = '#ddd';
                    }
                });
            });
        });

        // Form Validation
        document.getElementById('feedbackForm').addEventListener('submit', function(e) {
            const overallRating = document.getElementById('overallRating').value;
            if (!overallRating) {
                e.preventDefault();
                alert('Please provide an overall experience rating.');
                return;
            }
            
            // You can add more validation here
            console.log('Form submitted successfully!');
        });
    </script>
<script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
<script src="https://www.youtube.com/iframe_api"></script>

<script>
let slides = document.querySelectorAll('.video-slide');
let currentSlide = 0;
let players = {};

function loadYouTubeVideo(slideIndex) {
    let slide = slides[slideIndex];
    let videoID = slide.dataset.videoId;
    let container = slide.querySelector('.video-container');
    let poster = slide.querySelector(".video-poster");

    // Show poster
    poster.style.display = "block";
    poster.style.opacity = "1";

    // Clear previous iframe
    container.innerHTML = "";

    let divID = "player_" + slideIndex;
    let div = document.createElement("div");
    div.id = divID;
    container.appendChild(div);

    players[slideIndex] = new YT.Player(divID, {
        videoId: videoID,
        playerVars: {
            autoplay: 1,
            mute: 1,
            controls: 0,
            rel: 0,
            modestbranding: 1,
            iv_load_policy: 3,
            showinfo: 0,
            playsinline: 1
        },
        events: {
            onReady: function(event) {
                event.target.playVideo();
            },
            onStateChange: function(event) {
                if (event.data === YT.PlayerState.PLAYING) {
                    // Hide poster smoothly
                    poster.style.opacity = "0";
                    setTimeout(() => { poster.style.display = "none"; }, 500);
                }

                if (event.data === YT.PlayerState.ENDED) {
                    goToNextSlide();
                }
            }
        }
    });
}


function goToNextSlide() {

    slides[currentSlide].classList.remove('active');

    if (players[currentSlide]) {
        players[currentSlide].destroy();
    }

    currentSlide = (currentSlide + 1) % slides.length;

    slides[currentSlide].classList.add('active');
    loadYouTubeVideo(currentSlide);
}

function goToPrevSlide() {

    slides[currentSlide].classList.remove('active');

    if (players[currentSlide]) {
        players[currentSlide].destroy();
    }

    currentSlide = (currentSlide - 1 + slides.length) % slides.length;

    slides[currentSlide].classList.add('active');
    loadYouTubeVideo(currentSlide);
}

function onYouTubeIframeAPIReady() {
    loadYouTubeVideo(0);
}

document.getElementById('nextVideo').addEventListener('click', goToNextSlide);
document.getElementById('prevVideo').addEventListener('click', goToPrevSlide);



// Play / Pause
document.getElementById('playPauseVideo')?.addEventListener('click', () => {
    let player = players[currentSlide];
    if (!player) return;

    if (isPlaying) player.pauseVideo();
    else player.playVideo();

    isPlaying = !isPlaying;
});
</script>
<script>
document.getElementById('muteVideo').addEventListener('click', () => {
    let player = players[currentSlide];
    if (!player) return;

    if (player.isMuted()) {
        player.unMute();
        document.querySelector("#muteVideo i").classList.replace("fa-volume-mute","fa-volume-up");
    } else {
        player.mute();
        document.querySelector("#muteVideo i").classList.replace("fa-volume-up","fa-volume-mute");
    }
});

</script>
</body>
</html>