        <!-- Services Section -->
      <section id="services" class="services-section" style="background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 50%, #dbeafe 100%); padding: 80px 0; position: relative;">
            
            <!-- Decorative Pattern Overlay -->
            <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0.05; background-image: radial-gradient(circle, #3b82f6 1px, transparent 1px); background-size: 30px 30px;"></div>
            
            <div class="container" style="position: relative; z-index: 1;">
                <div class="row">
                    <div class="col-12">
                        <h2 class="section-title font-flair animate-on-scroll" style="color: #1e40af; margin-bottom: 3rem;">Tourism Services</h2>
                    </div>
