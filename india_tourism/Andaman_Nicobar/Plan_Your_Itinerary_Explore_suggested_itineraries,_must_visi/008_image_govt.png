                    </div>
                    
                    <div class="col-lg-4 col-md-6 animate-on-scroll">
                        <a href="https://dss.andamannicobar.gov.in/ShipETicketingWeb/Login.jsp" class="text-decoration-none" target="_blank">
                            <div class="service-card" style="background: white; border-radius: 16px; padding: 2rem; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.1); transition: transform 0.3s, box-shadow 0.3s; margin-bottom: 2rem;">
                                <div class="service-icon" style="width: 80px; height: 80px; margin: 0 auto 1.5rem; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); border-radius: 50%; font-size: 2rem; color: white; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);">
                                    <i class="fas fa-volcano"></i>
