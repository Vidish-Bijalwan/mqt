<style>
              
        .weather-widget {
            background: rgba(255,255,255,0.1);
            border-radius: 8px;
            padding: 8px 12px;
            margin-left: 15px;
            color: white;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 8px;
            min-width: 180px;
            backdrop-filter: blur(10px);
        }
        
        .weather-icon {
            font-size: 1.2rem;
        }
        
        .weather-temp {
            font-weight: bold;
            font-size: 1rem;
        }
        
        .weather-location {
            font-size: 0.8rem;
            opacity: 0.9;
        }
        
        .weather-loading {
            animation: pulse 1.5s ease-in-out infinite alternate;
        }
        
        @keyframes pulse {
            from { opacity: 0.6; }
            to { opacity: 1; }
        }
        
        .searchBtn, .sidePanelBtn {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.3);
            color: white;
            padding: 10px;
            border-radius: 5px;
            transition: all 0.3s ease;
        }
        
        .searchBtn:hover, .sidePanelBtn:hover {
            background: rgba(255,255,255,0.2);
            color: white;
        }
        
        /* Demo content */
        .demo-content {
            padding: 50px 0;
            text-align: center;
            background: linear-gradient(45deg, #f0f8ff, #e6f3ff);
        }
        
        .alert-weather {
            background: linear-gradient(45deg, #ff6b6b, #ee5a52);
            color: white;
            border: none;
            margin: 20px 0;
        }
    </style>
    <style>
        .video-slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100vh;
            display: none;
            overflow: hidden;
        }

        .video-slide.active {
            display: block;
        }

        .video-container {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 100%;
            height: 100%;
            transform: translate(-50%, -50%);
            pointer-events: none;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .video-container iframe {
            width: 100%;
            height: 100%;
            border: none;
        }

        .video-poster {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: contain; /* ✅ no cropping */
            background: black;   /* fills empty space nicely */
            z-index: 2; /* above video */
            transition: opacity 0.5s ease-in-out;
        }


    </style>
</head>

<body>
     <!-- Sticky Sidebar Start -->
      <style>
     .sticky-sidebar {
         position: fixed;
         top: 250px;
         right: 0;
         z-index: 1000;
         display: flex;
         flex-direction: column;
         gap: 10px;
     }
     .sticky-sidebar a {
         display: flex;
         align-items: center;
         justify-content: center;
         width: 38px;
         height: 38px;
         border-radius: 12px;
         margin-bottom: 4px;
         color: #fff;
         text-decoration: none;
         font-size: 24px;
         box-shadow: 0 2px 8px rgba(0,0,0,0.1);
         transition: transform 0.2s;
     }
     .sticky-sidebar a:hover {
         transform: scale(1.08);
         box-shadow: 0 4px 16px rgba(0,0,0,0.15);
     }
     .sticky-sidebar .home { background: #8f3cff; }
     .sticky-sidebar .twitter { background: #1da1f2; }
     .sticky-sidebar .whatsapp { background: #25d366; }
     .sticky-sidebar .youtube { background: #ff0000; }
     .sticky-sidebar .facebook { background: #1877f3; }
     .sticky-sidebar .instagram { background: #e1306c; }
     .sticky-sidebar .linkedin { background: #0077b5; }
