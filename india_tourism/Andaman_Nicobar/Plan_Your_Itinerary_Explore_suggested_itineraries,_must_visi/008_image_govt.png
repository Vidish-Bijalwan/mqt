    <style>
    .news-card {
  margin-bottom: 1.5rem;
  border: none;
  transition: transform 0.3s;
}
.news-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 4px 8px rgba(0,0,0,0.1);
}

.news-card .card-title {
  font-weight: 600;
}

.news-card .card-text {
  font-size: 0.95rem;
  color: #666;
}

.special-slider-container {
  position: relative;
